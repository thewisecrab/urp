{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urp.dev/schemas/urp_ledger_event.schema.json",
  "title": "URP Ledger Event",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "tenant",
    "created_at"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "^evt_[A-Za-z0-9_-]+$"
    },
    "event_type": {
      "type": "string"
    },
    "tenant": {
      "type": "string",
      "minLength": 1
    },
    "work_unit_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "manifest_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "policy_bundle_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "actor": {
      "type": [
        "string",
        "null"
      ]
    },
    "decision": {
      "type": [
        "string",
        "null"
      ]
    },
    "details": {
      "type": "object",
      "additionalProperties": true
    },
    "trace_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "prev_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "event_hash": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false
}
